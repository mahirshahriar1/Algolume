# ─────────────────────────────────────────────────────────────────────────────
# Optional: cloud sync (Google sign-in via Supabase).
#
# Algolume is local-first and fully usable WITHOUT these — sign-in just mirrors
# your lesson progress, notes, and solved problems to your account so they follow
# you across devices. If these are unset, the account button is hidden and nothing
# touches the network.
#
# 1. Create a project at https://supabase.com and copy these from
#    Project Settings → API:
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
#
# 2. Enable Google as an auth provider:
#    Supabase Dashboard → Authentication → Providers → Google (add your Google
#    OAuth client id/secret), and add your site URL + redirect URL under
#    Authentication → URL Configuration (e.g. http://localhost:5173 for dev).
#
# 3. Create the per-user state table with row-level security (SQL editor):
#
#    create table public.user_state (
#      user_id    uuid primary key references auth.users(id) on delete cascade,
#      state      jsonb not null default '{}'::jsonb,
#      updated_at timestamptz not null default now()
#    );
#    alter table public.user_state enable row level security;
#
#    create policy "own row - select" on public.user_state
#      for select using (auth.uid() = user_id);
#    create policy "own row - insert" on public.user_state
#      for insert with check (auth.uid() = user_id);
#    create policy "own row - update" on public.user_state
#      for update using (auth.uid() = user_id) with check (auth.uid() = user_id);
#
# That's it — the client reads/writes one JSON row per user and merges with the
# local data on sign-in (union of completed/solved, newest-wins per note).
# ─────────────────────────────────────────────────────────────────────────────

# Optional: "Submit an issue" form delivery. Without this, the form opens the
# user's mail client (mailto). With a free Web3Forms access key
# (https://web3forms.com, tied to your inbox) it emails you in the background.
# VITE_WEB3FORMS_KEY=your-web3forms-access-key
